{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"strict": true,
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"types": ["node"],
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["bin/**/*.js", "test/**/*.js"]
}
