{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://github.com/grainulation/bean/schemas/result.schema.json",
	"title": "bean-check result",
	"type": "object",
	"required": [
		"status",
		"blockers",
		"warnings",
		"notes",
		"coverage",
		"round",
		"certificate"
	],
	"properties": {
		"status": { "enum": ["ready", "blocked", "budget-exceeded"] },
		"blockers": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
		"warnings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
		"notes": { "type": "array", "items": { "type": "string" } },
		"coverage": {
			"type": "object",
			"properties": {
				"topics": { "type": "integer" },
				"active": { "type": "integer" },
				"total": { "type": "integer" }
			}
		},
		"round": { "type": "integer" },
		"max_rounds": { "type": ["integer", "null"] },
		"new_this_round": { "type": "integer" },
		"dry": { "type": "boolean" },
		"certificate": { "type": "string" }
	},
	"$defs": {
		"finding": {
			"type": "object",
			"required": ["code"],
			"properties": { "code": { "type": "string" } },
			"additionalProperties": true
		}
	}
}
