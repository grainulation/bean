{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://github.com/grainulation/bean/schemas/claim.schema.json",
	"title": "bean claim (Bran-IR)",
	"type": "object",
	"required": ["id", "type", "topic", "evidence"],
	"additionalProperties": true,
	"properties": {
		"id": { "type": "string", "minLength": 1 },
		"type": {
			"enum": [
				"constraint",
				"factual",
				"estimate",
				"risk",
				"recommendation",
				"feedback"
			]
		},
		"topic": { "type": "string", "minLength": 1 },
		"content": { "type": "string" },
		"evidence": {
			"enum": ["stated", "web", "documented", "tested", "production"]
		},
		"status": {
			"description": "active by default; superseded/rejected/resolved are terminal. Abstention is a TAG (needs-input/unknown), not a status.",
			"type": "string"
		},
		"source": {
			"type": "object",
			"properties": { "origin": { "type": "string" } }
		},
		"conflicts_with": { "type": "array", "items": { "type": "string" } },
		"resolved_by": { "type": ["string", "null"] },
		"tags": {
			"type": "array",
			"items": { "type": "string" },
			"description": "Convention: load-bearing | needs-input | unknown | confirmed-non-issue | residual | accepted"
		}
	}
}
